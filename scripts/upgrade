#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service=$app --action="stop" --log_path="systemd"

#=================================================
# UPDATE A CONFIG FILE
#=================================================
ynh_script_progression "Updating $app's configuration files..."

ynh_replace --match="ListenStream=.*" --replace="ListenStream=$port" --file="/lib/systemd/system/cockpit.socket"
systemctl daemon-reload
systemctl restart $app.socket

ynh_config_add --template="cockpit.conf" --destination="/etc/cockpit/cockpit.conf"
chmod 644 "/etc/cockpit/cockpit.conf"

if [[ $YNH_DEBIAN_VERSION == "bookworm" ]]
then
	chown root:$app "/etc/cockpit/cockpit.conf"
	usermod -a -G cockpit cockpit-ws
	usermod -a -G cockpit cockpit-wsinstance
elif [[ $YNH_DEBIAN_VERSION == "trixie" ]]
then
	if ynh_app_upgrading_from_version_before 337~ynh5 \
	&& find /usr/lib/systemd/system/cockpit* -type f -print | xargs grep -q '^DynamicUser=yes'
	then
		delete_system_user --username="cockpit-ws"
		delete_system_user --username="cockpit-wsinstance"
		delete_system_user --username="cockpit-session-socket"
		delete_system_user --username="cockpit-wsinstance-socket"
		delete_system_user --username="cockpit-systemd-service"
	fi
	myynh_handle_dynamicuser
fi

#=================================================
# REAPPLY SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

ynh_config_add_nginx

yunohost service add $app --description="Sysadmin login session in a Web browser" --test_status="systemctl is-active $app.socket" --log="/var/log/$app/$app.log"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service=$app --action="restart" --log_path="systemd"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
