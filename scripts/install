#!/bin/bash

source /usr/share/yunohost/helpers

#=================================================
# APP INITIAL CONFIGURATION
#=================================================
ynh_script_progression "Adding $app's configuration files..."

ynh_replace --match="ListenStream=.*" --replace="ListenStream=$port" --file="/lib/systemd/system/cockpit.socket"
systemctl daemon-reload
systemctl restart $app.socket

ynh_config_add --template="cockpit.conf" --destination="/etc/cockpit/cockpit.conf"
chmod 644 "/etc/cockpit/cockpit.conf"

if [[ $YNH_DEBIAN_VERSION == "bookworm" ]]
then
	chown root:$app "/etc/cockpit/cockpit.conf"

	usermod -a -G cockpit cockpit-ws
	usermod -a -G cockpit cockpit-wsinstance
fi

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations related to $app..."

ynh_config_add_nginx

yunohost service add $app --description="Sysadmin login session in a Web browser" --test_status="systemctl is-active $app.socket" --log="/var/log/$app/$app.log"

#=================================================
# TODO: DEBUG
#=================================================
ynh_script_progression "Debuging $app's systemd service..."

# grep -R "DynamicUser=yes" /usr/lib/systemd/system/cockpit*
# /usr/lib/systemd/system/cockpit.service:DynamicUser=yes
# /usr/lib/systemd/system/cockpit-session-socket-user.service:DynamicUser=yes
# /usr/lib/systemd/system/cockpit-wsinstance-http.service:DynamicUser=yes
# /usr/lib/systemd/system/cockpit-wsinstance-https@.service:DynamicUser=yes
# /usr/lib/systemd/system/cockpit-wsinstance-socket-user.service:DynamicUser=yes

getent passwd cockpit-systemd-service >/dev/null || adduser --system --group cockpit-systemd-service
getent passwd cockpit-wsinstance-socket >/dev/null || adduser --system --group cockpit-wsinstance-socket
getent passwd cockpit-session-socket >/dev/null || adduser --system --group cockpit-session-socket

# /usr/lib/systemd/system/cockpit.service:DynamicUser=yes
# User=cockpit-systemd-service
# Group=cockpit-wsinstance-socket
mkdir -p /usr/lib/systemd/system/cockpit.service.d
cat << 'EOF' > /usr/lib/systemd/system/cockpit.service.d/override.conf
[Service]
DynamicUser=no
EOF

# /usr/lib/systemd/system/cockpit-session-socket-user.service:DynamicUser=yes
# User=cockpit-session-socket
# Group=cockpit-session-socket
mkdir -p /usr/lib/systemd/system/cockpit-session-socket-user.service.d
cat << 'EOF' > /usr/lib/systemd/system/cockpit-session-socket-user.service.d/override.conf
[Service]
DynamicUser=no
EOF

# /usr/lib/systemd/system/cockpit-wsinstance-https@.service:DynamicUser=yes
# Group=cockpit-session-socket
mkdir -p /usr/lib/systemd/system/cockpit-wsinstance-https@.service.d
cat << 'EOF' > /usr/lib/systemd/system/cockpit-wsinstance-https@.service.d/override.conf
[Service]
DynamicUser=no
EOF

# /usr/lib/systemd/system/cockpit-wsinstance-socket-user.service:DynamicUser=yes
# User=cockpit-wsinstance-socket
# Group=cockpit-wsinstance-socket
mkdir -p /etc/systemd/system/cockpit-wsinstance-socket-user.service.d
cat << 'EOF' > /etc/systemd/system/cockpit-wsinstance-socket-user.service.d/override.conf
[Service]
DynamicUser=no
EOF

systemctl daemon-reload
# systemctl cat cockpit-wsinstance-socket-user.service
# systemctl status cockpit-wsinstance-socket-user.service -l
# journalctl -xeu cockpit-wsinstance-socket-user.service

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service=$app --action="restart" --log_path="systemd"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
